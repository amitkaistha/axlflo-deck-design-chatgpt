{
  "name": "axlflo-deck-system",
  "version": "5.10.0",
  "description": "AxlFlo versioned PowerPoint deck generation system",
  "private": true,
  "scripts": {
    "build": "npm run build:shift-json",
    "build:process-first": "node decks/process-first/build.js",
    "build:automate-a-mess": "node decks/automate-a-mess/build.js",
    "qa": "node scripts/run_full_validation.js",
    "qa:structural": "node qa/qa.js output/shift_to_scale_from_fresh_json.pptx output/shift_to_scale_from_fresh_json_manifest.json",
    "qa:content": "node qa/content_narrative.js output/shift_to_scale_from_fresh_json_manifest.json",
    "qa:visual": "node qa/visual_design.js output/shift_to_scale_from_fresh_json_manifest.json",
    "qa:critique": "node qa/creative_critique.js output/shift_to_scale_from_fresh_json_manifest.json",
    "validate:deck-json": "node scripts/validate_deck_json.js decks/shift-to-scale-json/content.json decks/shift-to-scale-json/layout.plan.json",
    "validate:fixtures": "node scripts/validate_golden_fixtures.js",
    "build:shift-veda": "node decks/shift-veda/build.js",
    "build:shift-json": "node decks/shift-to-scale-json/build_from_json.js",
    "build:microsoft-8-seconds": "node decks/input-enrichment-pilots/microsoft-8-seconds/build.js",
    "build:microsoft-8-seconds-independent": "node decks/input-enrichment-pilots/microsoft-8-seconds-independent/build.js",
    "qa:shift-json": "node qa/qa.js output/shift_to_scale_from_fresh_json.pptx output/shift_to_scale_from_fresh_json_manifest.json",
    "qa:feedback-regression": "node qa/feedback_regression.js output/shift_to_scale_from_fresh_json.pptx output/shift_to_scale_from_fresh_json_manifest.json"
  },
  "dependencies": {
    "adm-zip": "^0.5.10",
    "pptxgenjs": "^3.12.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-icons": "^4.12.0",
    "sharp": "^0.33.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "author": "Amit Kaistha <amit.kaistha@axlflo.ai>",
  "license": "UNLICENSED"
}
