{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://axlflo.ai/schemas/axlflo.enriched-brief.schema.json",
  "title": "AxlFlo Enriched Brief Schema",
  "description": "Structured argument layer created from raw user input before any slide JSON is written.",
  "type": "object",
  "required": ["brief", "sources", "argument", "intake_answers"],
  "additionalProperties": true,
  "properties": {
    "brief": {
      "type": "object",
      "required": ["project_name", "objective", "audience", "delivery_context"],
      "additionalProperties": true,
      "properties": {
        "project_name": { "type": "string" },
        "objective": { "type": "string" },
        "audience": { "type": "string" },
        "delivery_context": { "type": "string" },
        "desired_slide_count": { "type": "string" },
        "tone": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_include": {
          "type": "array",
          "items": { "type": "string" }
        },
        "must_avoid": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "intake_answers": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "audience": { "type": "string" },
        "decision_stage": { "type": "string" },
        "tone": { "type": "string" },
        "slide_count": { "type": "string" },
        "delivery_mode": { "type": "string" },
        "primary_action": { "type": "string" },
        "proof_level": { "type": "string" },
        "constraints": { "type": "string" }
      }
    },
    "sources": {
      "type": "array",
      "items": { "$ref": "#/$defs/source" }
    },
    "argument": {
      "type": "object",
      "required": ["story", "tension", "shift", "proof_needed", "cta", "memorable_line"],
      "additionalProperties": true,
      "properties": {
        "story": { "type": "string" },
        "tension": { "type": "string" },
        "shift": { "type": "string" },
        "stakes": { "type": "string" },
        "proof_needed": {
          "type": "array",
          "items": { "$ref": "#/$defs/proofNeed" }
        },
        "cta": { "$ref": "#/$defs/cta" },
        "memorable_line": { "type": "string" }
      }
    },
    "visual_opportunities": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "number_slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/visualOpportunity" }
        },
        "architecture_slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/visualOpportunity" }
        },
        "contrast_slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/visualOpportunity" }
        },
        "metaphor_slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/visualOpportunity" }
        },
        "case_study_slides": {
          "type": "array",
          "items": { "$ref": "#/$defs/visualOpportunity" }
        }
      }
    },
    "content_inventory": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "claims": {
          "type": "array",
          "items": { "type": "string" }
        },
        "proof_points": {
          "type": "array",
          "items": { "type": "string" }
        },
        "frameworks": {
          "type": "array",
          "items": { "type": "object", "additionalProperties": true }
        },
        "must_keep_phrases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "sensitive_or_legal_notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "agent_assumptions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "open_questions": {
      "type": "array",
      "items": { "$ref": "#/$defs/openQuestion" }
    },
    "approval_gates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_artifacts": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "slide_strategy_json": { "type": "string" },
        "render_json": { "type": "string" },
        "layout_plan_json": { "type": "string" }
      }
    }
  },
  "$defs": {
    "source": {
      "type": "object",
      "required": ["id", "type", "role", "priority"],
      "additionalProperties": true,
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "path_or_url": { "type": "string" },
        "role": { "type": "string" },
        "priority": { "type": "string", "enum": ["high", "medium", "low"] },
        "notes": { "type": "string" }
      }
    },
    "proofNeed": {
      "type": "object",
      "required": ["claim", "proof_type"],
      "additionalProperties": true,
      "properties": {
        "claim": { "type": "string" },
        "proof_type": { "type": "string" },
        "available_evidence": { "type": "string" },
        "gap": { "type": "string" }
      }
    },
    "cta": {
      "type": "object",
      "required": ["desired_action", "commercial_intent"],
      "additionalProperties": true,
      "properties": {
        "desired_action": { "type": "string" },
        "commercial_intent": { "type": "string" },
        "offer_structure": { "type": "string" },
        "contact": { "type": "string" }
      }
    },
    "visualOpportunity": {
      "type": "object",
      "required": ["idea", "why_this_form"],
      "additionalProperties": true,
      "properties": {
        "idea": { "type": "string" },
        "why_this_form": { "type": "string" },
        "possible_slide_role": { "type": "string" },
        "must_preserve": {
          "type": "array",
          "items": { "type": "string" }
        },
        "avoid": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "openQuestion": {
      "type": "object",
      "required": ["question", "why_it_matters", "default_assumption"],
      "additionalProperties": true,
      "properties": {
        "question": { "type": "string" },
        "why_it_matters": { "type": "string" },
        "default_assumption": { "type": "string" },
        "blocks_build": { "type": "boolean" }
      }
    }
  }
}
